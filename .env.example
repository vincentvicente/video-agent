# OpenAI API Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4-turbo-preview

# Whisper API Configuration (for transcription)
WHISPER_API_KEY=sk-your-api-key-here
WHISPER_MODEL=whisper-1

# Project Paths
WORKSPACE_DIR=/Users/vicentezhu/claude-workspace/data
VIDEOS_DIR=/Users/vicentezhu/claude-workspace/data/videos
CHUNKS_DIR=/Users/vicentezhu/claude-workspace/data/chunks
EMBEDDINGS_DIR=/Users/vicentezhu/claude-workspace/data/embeddings
CACHE_DIR=/Users/vicentezhu/claude-workspace/data/cache

# Vector Database Configuration
VECTOR_DB_PATH=/Users/vicentezhu/claude-workspace/data/embeddings/video_rag.sqlite
FAISS_INDEX_PATH=/Users/vicentezhu/claude-workspace/data/embeddings/faiss.index
EMBEDDING_DIMENSION=1536

# Text Processing Configuration
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=50
MAX_TOKENS_PER_CHUNK=600

# Video Processing Configuration
VIDEO_DOWNLOAD_TIMEOUT=300
AUDIO_FORMAT=wav
TRANSCRIPT_FORMATS=vtt,txt,json

# Logging
LOG_LEVEL=info
LOG_DIR=/Users/vicentezhu/claude-workspace/logs

# Performance
MAX_CONCURRENT_DOWNLOADS=3
CACHE_ENABLED=true
CACHE_TTL=86400
