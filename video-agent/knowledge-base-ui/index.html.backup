<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>智能视频知识库 - 自动化处理</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            margin-bottom: 20px;
        }

        .header h1 {
            color: #667eea;
            font-size: 32px;
            margin-bottom: 15px;
        }

        /* Video Input Panel */
        .video-input-panel {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            margin-bottom: 20px;
        }

        .video-input-panel h2 {
            color: #667eea;
            font-size: 20px;
            margin-bottom: 15px;
        }

        .url-input-group {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }

        .url-input-group input {
            flex: 1;
            padding: 12px 20px;
            border: 2px solid #e0e0e0;
            border-radius: 25px;
            font-size: 16px;
            outline: none;
        }

        .url-input-group input:focus {
            border-color: #667eea;
        }

        .url-input-group button {
            padding: 12px 30px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 25px;
            font-size: 16px;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .url-input-group button:hover {
            transform: translateY(-2px);
        }

        .url-input-group button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .processing-status {
            display: none;
            background: #f8f9fa;
            padding: 15px;
            border-radius: 10px;
            margin-top: 15px;
        }

        .processing-status.active {
            display: block;
        }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: #e0e0e0;
            border-radius: 4px;
            overflow: hidden;
            margin: 10px 0;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
            transition: width 0.3s;
            width: 0%;
        }

        .status-message {
            color: #666;
            font-size: 14px;
            margin-top: 5px;
        }

        /* Video Library */
        .video-library {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 15px;
            max-height: 150px;
            overflow-y: auto;
        }

        .video-item {
            background: white;
            padding: 10px 15px;
            border-radius: 8px;
            margin-bottom: 8px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.2s;
        }

        .video-item:hover {
            background: #667eea;
            color: white;
        }

        .video-item.active {
            background: #667eea;
            color: white;
        }

        .video-info {
            flex: 1;
        }

        .video-title {
            font-weight: 500;
            font-size: 14px;
        }

        .video-meta {
            font-size: 12px;
            opacity: 0.8;
            margin-top: 3px;
        }

        .panel {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            padding: 25px;
            height: 600px;
            display: flex;
            flex-direction: column;
        }

        .panel h2 {
            color: #667eea;
            font-size: 24px;
            margin-bottom: 20px;
        }

        .main-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        @media (max-width: 1024px) {
            .main-content {
                grid-template-columns: 1fr;
            }
        }

        .search-box {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .search-box input {
            flex: 1;
            padding: 12px 20px;
            border: 2px solid #e0e0e0;
            border-radius: 25px;
            font-size: 16px;
            outline: none;
        }

        .search-box input:focus {
            border-color: #667eea;
        }

        .search-box button {
            padding: 12px 30px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 25px;
            cursor: pointer;
        }

        .results-container {
            flex: 1;
            overflow-y: auto;
            padding-right: 10px;
        }

        .result-item {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 15px;
            border-left: 4px solid #667eea;
        }

        .result-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .similarity-badge {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 4px 12px;
            border-radius: 15px;
            font-size: 12px;
        }

        .timestamp {
            color: #667eea;
            font-weight: bold;
            font-size: 14px;
        }

        .result-text {
            color: #333;
            line-height: 1.6;
            font-size: 14px;
        }

        .transcript-container {
            flex: 1;
            overflow-y: auto;
        }

        .transcript-item {
            padding: 15px;
            border-bottom: 1px solid #e0e0e0;
        }

        .transcript-item:hover {
            background: #f8f9fa;
        }

        .transcript-time {
            color: #667eea;
            font-weight: bold;
            font-size: 12px;
            margin-bottom: 5px;
        }

        .transcript-text {
            color: #333;
            line-height: 1.6;
            font-size: 14px;
        }

        .qa-container {
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .messages {
            flex: 1;
            overflow-y: auto;
            margin-bottom: 20px;
        }

        .message {
            margin-bottom: 20px;
            animation: fadeIn 0.3s;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message.user {
            text-align: right;
        }

        .message-bubble {
            display: inline-block;
            padding: 12px 18px;
            border-radius: 18px;
            max-width: 80%;
        }

        .message.user .message-bubble {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .message.assistant .message-bubble {
            background: #f8f9fa;
            color: #333;
        }

        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: #999;
        }

        .empty-state .icon {
            font-size: 64px;
            margin-bottom: 20px;
        }

        .suggestions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 15px;
        }

        .suggestion-chip {
            background: #e8eaf6;
            color: #667eea;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .suggestion-chip:hover {
            background: #667eea;
            color: white;
        }

        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb {
            background: #667eea;
            border-radius: 10px;
        }

        .stats {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-top: 10px;
            font-size: 14px;
            color: #666;
        }

        .stat-item {
            display: flex;
            align-items: center;
            gap: 5px;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>🎬 智能视频知识库 - 自动化处理</h1>
            <div class="stats" id="stats">
                <div class="stat-item"><span>⏱️</span><span id="duration">-</span></div>
                <div class="stat-item"><span>🗣️</span><span id="language">-</span></div>
                <div class="stat-item"><span>🧬</span><span id="vectors">-</span></div>
            </div>
        </div>

        <!-- Video Input Panel -->
        <div class="video-input-panel">
            <h2>📹 添加新视频到知识库</h2>
            <div class="url-input-group">
                <input
                    type="text"
                    id="video-url-input"
                    placeholder="粘贴 YouTube 视频链接... 例如: https://www.youtube.com/watch?v=xxxxx"
                    onkeypress="if(event.key==='Enter') processNewVideo()"
                />
                <button id="process-btn" onclick="processNewVideo()">🚀 自动处理</button>
            </div>

            <!-- Processing Status -->
            <div class="processing-status" id="processing-status">
                <strong>处理中...</strong>
                <div class="progress-bar">
                    <div class="progress-fill" id="progress-fill"></div>
                </div>
                <div class="status-message" id="status-message">准备开始...</div>
            </div>

            <!-- Video Library -->
            <div class="video-library" id="video-library" style="display: none;">
                <!-- Videos will be loaded here -->
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Left Column -->
            <div style="display: flex; flex-direction: column; gap: 20px;">
                <!-- Search Panel -->
                <div class="panel" style="height: 400px;">
                    <h2>🔍 语义搜索</h2>
                    <div class="search-box">
                        <input
                            type="text"
                            id="search-input"
                            placeholder="搜索视频内容..."
                            onkeypress="if(event.key==='Enter') search()"
                        />
                        <button onclick="search()">搜索</button>
                    </div>
                    <div class="results-container" id="search-results">
                        <div class="empty-state">
                            <div class="icon">🔍</div>
                            <p>输入关键词开始搜索</p>
                        </div>
                    </div>
                </div>

                <!-- QA Panel -->
                <div class="panel" style="height: 380px;">
                    <h2>💬 智能问答</h2>
                    <div class="qa-container">
                        <div class="messages" id="messages">
                            <div class="empty-state">
                                <div class="icon">💡</div>
                                <p>提问任何关于视频的问题</p>
                            </div>
                        </div>
                        <div class="search-box">
                            <input
                                type="text"
                                id="question-input"
                                placeholder="输入问题..."
                                onkeypress="if(event.key==='Enter') askQuestion()"
                            />
                            <button onclick="askQuestion()">提问</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Transcript -->
            <div class="panel">
                <h2>📄 完整转录</h2>
                <div class="transcript-container" id="transcript">
                    <div class="empty-state">
                        <div class="icon">📺</div>
                        <p>选择或添加视频查看转录</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let currentVideoId = null;
        let processingIntervalId = null;

        // Load available videos
        async function loadVideos() {
            try {
                const response = await fetch('/api/videos');
                const videos = await response.json();

                if (videos.length > 0) {
                    const library = document.getElementById('video-library');
                    library.style.display = 'block';
                    library.innerHTML = videos.map(v => `
                        <div class="video-item ${v.id === currentVideoId ? 'active' : ''}"
                             onclick="selectVideo('${v.id}')">
                            <div class="video-info">
                                <div class="video-title">📺 ${v.id}</div>
                                <div class="video-meta">
                                    ${Math.floor(v.duration / 60)}分钟 |
                                    ${v.language === 'zh' ? '中文' : v.language} |
                                    ${v.chunk_count} 个语义块
                                </div>
                            </div>
                        </div>
                    `).join('');

                    // Load first video if none selected
                    if (!currentVideoId) {
                        selectVideo(videos[0].id);
                    }
                }
            } catch (error) {
                console.error('Load videos error:', error);
            }
        }

        // Select video
        async function selectVideo(videoId) {
            try {
                const response = await fetch('/api/set-video', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ videoId })
                });

                if (response.ok) {
                    currentVideoId = videoId;
                    await loadVideoInfo();
                    await loadTranscript();
                    loadVideos(); // Refresh to update active state
                }
            } catch (error) {
                console.error('Select video error:', error);
            }
        }

        // Process new video
        async function processNewVideo() {
            const input = document.getElementById('video-url-input');
            const url = input.value.trim();

            if (!url) {
                alert('请输入视频URL');
                return;
            }

            if (!url.includes('youtube.com/watch')) {
                alert('请输入有效的YouTube视频链接');
                return;
            }

            const btn = document.getElementById('process-btn');
            const status = document.getElementById('processing-status');

            btn.disabled = true;
            status.classList.add('active');

            try {
                const response = await fetch('/api/process-video', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ url })
                });

                const data = await response.json();

                if (data.status === 'exists') {
                    alert('视频已在知识库中！');
                    selectVideo(data.videoId);
                    status.classList.remove('active');
                    btn.disabled = false;
                    return;
                }

                if (data.status === 'started') {
                    // Start polling for progress
                    startProgressPolling(data.videoId);
                }
            } catch (error) {
                alert('处理失败: ' + error.message);
                status.classList.remove('active');
                btn.disabled = false;
            }
        }

        // Poll processing status
        function startProgressPolling(videoId) {
            processingIntervalId = setInterval(async () => {
                try {
                    const response = await fetch(`/api/process-status/${videoId}`);
                    const data = await response.json();

                    document.getElementById('progress-fill').style.width = data.progress + '%';
                    document.getElementById('status-message').textContent = data.message || '处理中...';

                    if (data.status === 'completed') {
                        clearInterval(processingIntervalId);
                        document.getElementById('processing-status').classList.remove('active');
                        document.getElementById('process-btn').disabled = false;
                        document.getElementById('video-url-input').value = '';
                        alert('✅ 视频处理完成！');
                        await loadVideos();
                        selectVideo(videoId);
                    } else if (data.status === 'failed') {
                        clearInterval(processingIntervalId);
                        document.getElementById('processing-status').classList.remove('active');
                        document.getElementById('process-btn').disabled = false;
                        alert('❌ 处理失败: ' + data.message);
                    }
                } catch (error) {
                    console.error('Progress poll error:', error);
                }
            }, 2000);
        }

        // Load video info
        async function loadVideoInfo() {
            try {
                const response = await fetch('/api/video-info');
                const info = await response.json();

                document.getElementById('duration').textContent =
                    `${Math.floor(info.duration / 60)}分${Math.floor(info.duration % 60)}秒`;
                document.getElementById('language').textContent =
                    info.language === 'zh' ? '中文' : info.language;
                document.getElementById('vectors').textContent =
                    `${info.vector_count} 个向量`;
            } catch (error) {
                console.error('Load video info error:', error);
            }
        }

        // Load transcript
        async function loadTranscript() {
            try {
                const response = await fetch('/api/transcript');
                const segments = await response.json();

                const container = document.getElementById('transcript');
                container.innerHTML = segments.map(seg => `
                    <div class="transcript-item">
                        <div class="transcript-time">${seg.start}</div>
                        <div class="transcript-text">${seg.text}</div>
                    </div>
                `).join('');
            } catch (error) {
                console.error('Load transcript error:', error);
            }
        }

        // Search
        async function search() {
            const query = document.getElementById('search-input').value.trim();
            if (!query) return;

            const container = document.getElementById('search-results');
            container.innerHTML = '<div class="empty-state"><div class="icon">⏳</div><p>搜索中...</p></div>';

            try {
                const response = await fetch('/api/search', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ query })
                });

                const results = await response.json();

                if (results.length === 0) {
                    container.innerHTML = '<div class="empty-state"><div class="icon">😕</div><p>未找到相关内容</p></div>';
                    return;
                }

                container.innerHTML = results.map(result => `
                    <div class="result-item">
                        <div class="result-header">
                            <span class="timestamp">${result.timestamp || '未知'}</span>
                            <span class="similarity-badge">${(result.similarity * 100).toFixed(1)}% 匹配</span>
                        </div>
                        <div class="result-text">${result.text}</div>
                    </div>
                `).join('');
            } catch (error) {
                console.error('Search error:', error);
                container.innerHTML = '<div class="empty-state"><div class="icon">❌</div><p>搜索失败</p></div>';
            }
        }

        // Ask question
        async function askQuestion() {
            const input = document.getElementById('question-input');
            const question = input.value.trim();
            if (!question) return;

            const messagesContainer = document.getElementById('messages');

            if (messagesContainer.querySelector('.empty-state')) {
                messagesContainer.innerHTML = '';
            }

            const userMessage = document.createElement('div');
            userMessage.className = 'message user';
            userMessage.innerHTML = `<div class="message-bubble">${question}</div>`;
            messagesContainer.appendChild(userMessage);

            input.value = '';
            messagesContainer.scrollTop = messagesContainer.scrollHeight;

            try {
                const response = await fetch('/api/ask', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ question })
                });

                const data = await response.json();

                const assistantMessage = document.createElement('div');
                assistantMessage.className = 'message assistant';
                assistantMessage.innerHTML = `<div class="message-bubble">${data.answer}</div>`;
                messagesContainer.appendChild(assistantMessage);

                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            } catch (error) {
                console.error('Ask error:', error);
            }
        }

        // Initialize
        loadVideos();
    </script>
</body>
</html>
